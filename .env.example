PORT=3000
JWT_SECRET=pizza-delivery-local-secret

# Optional MongoDB connection. Leave empty to use in-memory demo data.
MONGO_URI=

# Default demo accounts
DEFAULT_ADMIN_EMAIL=admin@pizzadelivery.local
DEFAULT_ADMIN_PASSWORD=Admin@123
DEFAULT_USER_EMAIL=user@pizzadelivery.local
DEFAULT_USER_PASSWORD=User@12345

# Optional admin registration code
ADMIN_INVITE_CODE=

# Optional SMTP settings
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SENDER_EMAIL=
SENDER_PASSWORD=

# Optional Razorpay settings
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
